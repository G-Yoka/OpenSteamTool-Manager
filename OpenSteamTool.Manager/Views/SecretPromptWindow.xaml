<Window x:Class="OpenSteamTool.Manager.Views.SecretPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title, RelativeSource={RelativeSource Self}}"
        Icon="/Assets/Yoka.ico"
        Width="520" Height="240"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="White">
    <StackPanel Margin="18">
        <TextBlock x:Name="PromptMessage" TextWrapping="Wrap" Margin="0,0,0,12" />
        <PasswordBox x:Name="SecretInput" Margin="0,0,0,14" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="确认" Width="84" Margin="0,0,8,0" IsDefault="True" Click="OnConfirmClick" />
            <Button Content="取消" Width="84" IsCancel="True" Click="OnCancelClick" />
        </StackPanel>
    </StackPanel>
</Window>
